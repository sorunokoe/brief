{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Brief",
  "scopeName": "source.brief",
  "fileTypes": ["brief"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#decorator-builtin" },
    { "include": "#decorator" },
    { "include": "#skill-perform" },
    { "include": "#keyword" },
    { "include": "#type-name" },
    { "include": "#operator" },
    { "include": "#number" },
    { "include": "#identifier" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.double-slash.brief",
      "match": "//.*$"
    },
    "string": {
      "name": "string.quoted.double.brief",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.brief", "match": "\\\\." }
      ]
    },
    "decorator-builtin": {
      "name": "storage.modifier.brief",
      "match": "@(BriefBuilder|once|mcp|url|nonEmpty|matches|deprecated|experimental|internal)\\b"
    },
    "decorator": {
      "name": "entity.name.tag.brief",
      "match": "@[A-Za-z][A-Za-z0-9_]*"
    },
    "skill-perform": {
      "comment": "Highlights `perform SkillName.method` — skill name gets distinct color",
      "match": "\\b(perform)\\s+([A-Z][A-Za-z0-9_]*)(\\.)",
      "captures": {
        "1": { "name": "keyword.control.brief" },
        "2": { "name": "support.class.skill.brief" },
        "3": { "name": "punctuation.accessor.brief" }
      }
    },
    "keyword": {
      "patterns": [
        {
          "name": "keyword.control.brief",
          "match": "\\b(perform|await|return|let|if|else|while|for|break|continue|match|spawn)\\b"
        },
        {
          "name": "keyword.declaration.brief",
          "match": "\\b(task|step|test|import|skill|sealed|type|struct|protocol|effect|fn|async|interface|module)\\b"
        },
        {
          "name": "keyword.other.brief",
          "match": "\\b(goal|uses|extras|display|from|assert|where|init)\\b"
        },
        {
          "name": "constant.language.brief",
          "match": "\\b(true|false|null|ok|err|some|none)\\b"
        }
      ]
    },
    "type-name": {
      "name": "entity.name.type.brief",
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
    },
    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.brief",
          "match": "(->|=>|\\?|\\|[^|]|=)"
        },
        {
          "name": "punctuation.brief",
          "match": "[{}()\\[\\]<>,;:]"
        }
      ]
    },
    "number": {
      "name": "constant.numeric.brief",
      "match": "\\b[0-9]+(\\.([0-9]+))?\\b"
    },
    "identifier": {
      "name": "variable.other.brief",
      "match": "\\b[a-z_][A-Za-z0-9_]*\\b"
    }
  }
}
