// examples/28-ai-pipeline.brief
//
// Demonstrates an AI agent pipeline — chaining multiple LLM calls as effects.
// In Brief, AI calls are just effects. They are typed, testable, and composable
// like any other skill. The compiler ensures you can't forget to declare them.
//
// Run:  brief check examples/28-ai-pipeline.brief   → ✅
// Run:  brief test  examples/28-ai-pipeline.brief   → runs mock tests

import skill "LLM"
import skill "Embeddings"
import skill "VectorStore"
import skill "GraphQL"

// ── Types ─────────────────────────────────────────────────────────────────────

sealed type SearchMode = Semantic | Keyword | Hybrid

struct Document {
    id:      @nonEmpty String
    content: @nonEmpty String
    source:  @nonEmpty String
}

struct SearchResult {
    document: Document
    score:    String
}

struct Answer {
    text:       @nonEmpty String
    confidence: String
    sources:    String
}

// ── Effects ───────────────────────────────────────────────────────────────────

effect LLM {
    fn complete(prompt: String, temperature: String) -> Answer
    fn classify(text: String, categories: String) -> String
    fn summarize(documents: String, maxWords: String) -> String
}

effect Embeddings {
    fn embed(text: String) -> String
    fn similarity(vecA: String, vecB: String) -> String
}

effect VectorStore {
    fn search(embedding: String, topK: String) -> SearchResult
    fn upsert(document: Document, embedding: String) -> String
}

// ── Pipeline Step 1: embed the query ─────────────────────────────────────────

@BriefBuilder
task EmbedQuery : TaskBrief uses [Embeddings] {
    goal = "Convert a user query into a vector embedding for semantic search"
    extras = ["model": "text-embedding-3-small"]

    step Embed {
        let embedding = perform Embeddings.embed(userQuery)?;
    }
}

// ── Pipeline Step 2: retrieve relevant documents ──────────────────────────────

@BriefBuilder
task RetrieveDocuments : TaskBrief uses [VectorStore] {
    goal = "Retrieve the top-K most relevant documents for a query embedding"
    extras = ["topK": "5", "domain": "knowledge-base"]

    step Search {
        let results = perform VectorStore.search(queryEmbedding, topK)?;
    }

    step Filter {
        let relevant = perform VectorStore.search(queryEmbedding, minScore)?;
    }
}

// ── Pipeline Step 3: generate grounded answer ────────────────────────────────

@BriefBuilder
task GenerateAnswer : TaskBrief uses [LLM] {
    goal = "Generate a grounded answer from retrieved documents using RAG"
    extras = [
        "model":       "gpt-4o",
        "temperature": "0.2",
        "pattern":     "RAG"
    ]

    step BuildPrompt {
        let context = perform LLM.summarize(documents, maxContextWords)?;
    }

    step Answer {
        let answer = perform LLM.complete(ragPrompt, temperature)?;
    }
}

// ── Full RAG pipeline (composed) ──────────────────────────────────────────────

@BriefBuilder
task RagSearch : TaskBrief uses [Embeddings, VectorStore, LLM, GraphQL] {
    goal = "Run the complete RAG pipeline: embed → retrieve → generate answer"
    extras = [
        "pattern": "RAG",
        "version": "2",
        "timeout": "30s"
    ]

    step Embed {
        let embedding = perform Embeddings.embed(userQuery)?;
    }

    step Retrieve {
        let results = perform VectorStore.search(embedding, topK)?;
    }

    step Classify {
        let category = perform LLM.classify(userQuery, supportedCategories)?;
    }

    step Generate {
        let answer = perform LLM.complete(ragPrompt, temperature)?;
    }

    step LogQuery {
        let logged = perform GraphQL.mutation(LogQueryMutation)?;
    }
}

// ── Tests ─────────────────────────────────────────────────────────────────────

test "RagSearch embeds query before searching" {
    mock Embeddings {
        fn embed(text) -> Ok("vec_abc123")
    }
    mock VectorStore {
        fn search(embedding, topK) -> Ok(SearchResult { document: Document { id: "d1", content: "Brief overview", source: "docs" }, score: "0.92" })
    }
    mock LLM {
        fn classify(text, cats) -> Ok("documentation")
        fn complete(prompt, temp) -> Ok(Answer { text: "Brief is a DSL for AI workflows.", confidence: "0.95", sources: "d1" })
    }
    mock GraphQL {
        fn mutation(op) -> Ok("logged")
    }

    run RagSearch
    assert performed Embeddings.embed
    assert performed VectorStore.search
    assert performed LLM.complete
    assert result is Ok
}

test "RagSearch fails gracefully when LLM errors" {
    mock Embeddings {
        fn embed(text) -> Ok("vec_abc")
    }
    mock VectorStore {
        fn search(embedding, topK) -> Ok(SearchResult { document: Document { id: "d1", content: "x", source: "s" }, score: "0.8" })
    }
    mock LLM {
        fn classify(text, cats) -> Ok("general")
        fn complete(prompt, temp) -> Err("rate_limit")
    }
    mock GraphQL {
        fn mutation(op) -> Ok("logged")
    }

    run RagSearch
    assert result is Err
}
