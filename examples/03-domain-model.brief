import skill "GraphQL"

@BriefBuilder
task UserDomainModel : TaskBrief uses [GraphQL] {
    goal   = "Define the User domain model from the GraphQL schema"
    extras = [
        "graphqlOperation": "UserProfileQuery",
        "targetLayer": "domain"
    ]

    step ExtractSchema {
        let schema = perform GraphQL.schema(UserProfileQuery)?;
    }

    step GenerateModel {
        let model = perform GraphQL.generateDomainModel(schema)?;
    }
}
